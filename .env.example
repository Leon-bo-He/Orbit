DATABASE_URL=postgres://orbit:secret@localhost:5432/orbit
TEST_DATABASE_URL=postgres://orbit:secret@localhost:5433/orbit_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
WECHAT_APP_ID=
WECHAT_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Publishing integration (M1+) — see docs/PUBLISHING_INTEGRATION.md
# RUNNER_URL: where the playwright-runner sidecar listens.
# RUNNER_TOKEN: shared secret between API and runner. Generate ≥16 random bytes.
# STORAGE_STATE_ENCRYPTION_KEY: 32 random bytes, base64-encoded. Used to AES-256-GCM
#   encrypt platform-account cookie blobs at rest. Generate with:
#     node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
# RUNNER_MAX_BROWSERS: parallel publishing jobs cap.
# PUBLISHING_JOB_TIMEOUT_MS: per-job timeout (mutex TTL = this + 30s).
# PUBLISHING_HEADED: 'true' opens visible Chromium (dev only).
# PUBLISHING_UPLOAD_DIR: path inside the runner container where API writes media.
RUNNER_URL=http://localhost:4000
RUNNER_TOKEN=
STORAGE_STATE_ENCRYPTION_KEY=
RUNNER_MAX_BROWSERS=4
PUBLISHING_JOB_TIMEOUT_MS=300000
PUBLISHING_HEADED=false
PUBLISHING_UPLOAD_DIR=/shared/uploads
